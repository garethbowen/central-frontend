{
  "extends": "./tsconfig.app.json",
  "include": [
    "../../common/src/**/*.ts",
    "../../common/types/**/*.ts",
    "env.d.ts",
    "src/components/__tests__",
    "tests",
    "tests-examples",
    "src/components/**/*.vue",
    "src/components/**/*.ts",
    "src/lib/**/*.ts",
    "src/odk-theme-preset.ts"
  ],
  "exclude": ["../common/src/test/**/*.ts"],
  "compilerOptions": {
    "composite": true,
    "rootDir": "./",
    "types": ["node", "jsdom", "vite/client"],
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"],
      "@locales/*": ["./locales/*"],
      "@getodk/common/test-utils/*": ["../../common/test-utils/*"],
      "@getodk/common/types/*": ["../../common/types/*"],
      "@getodk/common/*": ["../../common/src/*"]
    }
  }
}
