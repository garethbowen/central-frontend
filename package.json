{
  "name": "odk-central-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "          nf start vite,nginx-docker",
    "dev-no-docker": "nf start vite,nginx-host",
    "dev:build": "nf start build,nginx-docker",
    "dev-no-docker:build": "nf start build,nginx-host",
    "build": "vite build",
    "eslint": "eslint --max-warnings 0 --cache --ext .js,.vue e2e-tests/ bin/ *.js && npm run eslint --workspaces",
    "eslint:fix": "eslint --max-warnings 0 --fix --cache --ext .js,.vue apps/*/src/ apps/*/test/ bin/ apps/*/bin/ *.js",
    "lint": "npm run eslint && npm run transifex:lint",
    "lint:fix": "npm run eslint:fix && npm run transifex:fix",
    "test": "./apps/central/test/run.sh",
    "test:e2e": "e2e-tests/run-tests.sh",
    "transifex:fix": "node apps/central/bin/transifex/restructure.js > apps/central/apps/central/transifex/strings_en.json",
    "transifex:lint": "bash -c 'diff apps/central/transifex/strings_en.json <(node apps/central/bin/transifex/restructure.js)'"
  },
  "volta": {
    "node": "24.13.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@eslint/js": "^8.57.0",
    "@faker-js/faker": "^9.7.0",
    "@intlify/unplugin-vue-i18n": "^6.0.8",
    "@playwright/test": "^1.51.1",
    "@tsconfig/node20": "^20.1.8",
    "@types/eslint": "^9.6.1",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/geojson": "^7946.0.16",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vitest/browser-playwright": "^4.0.18",
    "@vue/cli-service": "^5.0.8",
    "@vue/compiler-sfc": "~3",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "chai": "^5.1.1",
    "chai-as-promised": "^8.0.0",
    "comment-json": "~4",
    "eslint": "^9.39.4",
    "eslint-config-airbnb-extended": "^3.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^62.8.0",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "foreman": "^3.0.1",
    "jsqr": "~1.0",
    "karma": "~6",
    "karma-chrome-launcher": "~3",
    "karma-mocha": "~2.0",
    "karma-source-map-support": "^1.4.0",
    "karma-sourcemap-loader": "~0.3",
    "karma-spec-reporter": "0.0.32",
    "karma-webpack": "^5.0.0",
    "mocha": "^10.1.0",
    "npm-run-all2": "^8.0.4",
    "only-allow": "^1.2.1",
    "organize-imports-cli": "^0.10.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "raw-loader": "^4.0.2",
    "rimraf": "^6.1.3",
    "sass": "~1",
    "sass-loader": "^13.2.0",
    "sinon": "~9",
    "turbo": "^2.8.16",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "util": "^0.12.5",
    "vite": "^6.3.5",
    "vitest": "^4.0.18",
    "vue": "^3.5.29",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.1.5"
  },
  "engines": {
    "node": "24",
    "npm": "11"
  }
}
