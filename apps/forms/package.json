{
  "name": "@getodk/forms",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:translations": "node ../../packages/web-forms/bin/merge-translations.js",
    "lint": "eslint . --report-unused-disable-directives --cache --max-warnings 0",
    "lint:fix": "eslint . --fix --report-unused-disable-directives --cache --max-warnings 0",
    "test": "vitest run",
    "translations:pull": "cd ../.. && tx pull -r web_forms.app -a -f --mode translator",
    "translations:push": "cd ../.. && tx push -r web_forms.app -s"
  },
  "dependencies": {
    "@formatjs/intl": "^4.1.4",
    "primevue": "4.3.3",
    "vue": "^3.5.29",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^27.4.0",
    "vitest": "^4.0.18"
  }
}
