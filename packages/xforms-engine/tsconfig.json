{
  "extends": "../tsconfig.json",
  "include": ["src", "vite-env.d.ts"],
  "compilerOptions": {
    "declarationDir": "./dist",
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "lib": ["DOM", "ES2022"],
    "skipLibCheck": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "paths": {
      "@getodk/common/test-utils/*": ["../../common/test-utils/*"],
      "@getodk/common/types/*": ["../../common/types/*"],
      "@getodk/common/*": ["../../common/src/*"]
    },
    "types": ["node", "vite/client"]
  }
}
